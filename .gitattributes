# Set default behavior to automatically normalize line endings
* text=auto

# Python files
*.py text eol=lf
*.pyw text eol=lf
*.pyi text eol=lf

# Configuration files
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.conf text eol=lf

# Documentation
*.md text eol=lf
*.rst text eol=lf
*.txt text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Batch files (Windows)
*.bat text eol=crlf
*.cmd text eol=crlf

# CloudFormation templates
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf

# Docker files
Dockerfile text eol=lf
*.dockerfile text eol=lf
.dockerignore text eol=lf

# Git files
.gitignore text eol=lf
.gitattributes text eol=lf

# Requirements and setup files
requirements*.txt text eol=lf
setup.py text eol=lf
pyproject.toml text eol=lf

# Environment files
.env* text eol=lf
env.example text eol=lf

# Web files
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf

# Data files (treat as text but don't normalize)
*.csv text
*.tsv text
*.json text

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.tar.bz2 binary
*.tar.xz binary
*.rar binary
*.7z binary

# Executables
*.exe binary
*.dll binary
*.so binary
*.dylib binary

# Archives
*.zip binary
*.tar.gz binary
*.tar.bz2 binary
*.tar.xz binary
*.rar binary
*.7z binary

# Database files
*.db binary
*.sqlite binary
*.sqlite3 binary

# Model files
*.model binary
*.pkl binary
*.joblib binary
*.h5 binary
*.hdf5 binary

# Large data files (use Git LFS if needed)
*.parquet filter=lfs diff=lfs merge=lfs -text
*.feather filter=lfs diff=lfs merge=lfs -text
*.arrow filter=lfs diff=lfs merge=lfs -text

# Jupyter notebooks
*.ipynb text

# Markdown files should be normalized
*.md text eol=lf

# YAML files should be normalized
*.yaml text eol=lf
*.yml text eol=lf

# JSON files should be normalized
*.json text eol=lf

# Python files should be normalized
*.py text eol=lf

# Shell scripts should be normalized
*.sh text eol=lf

# Docker files should be normalized
Dockerfile text eol=lf
*.dockerfile text eol=lf

# Make sure these files are treated as text
LICENSE text eol=lf
README.md text eol=lf
CONTRIBUTING.md text eol=lf
CHANGELOG.md text eol=lf

# Ensure these files are never normalized
*.patch -text
*.diff -text

# Exclude from diff
*.min.js -diff
*.min.css -diff

# Exclude from merge
*.lock -merge
