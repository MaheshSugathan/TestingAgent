# AWS Configuration
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# AgentCore Configuration
AGENTCORE_ENABLED=true
AGENTCORE_BASE_URL=http://localhost:8000
AGENTCORE_BILL_AGENT_NAME=bill
AGENTCORE_BILL_TIMEOUT=60
AGENTCORE_BILL_MAX_RETRIES=3

# Bedrock Configuration (for LLM-as-a-Judge evaluation only)
BEDROCK_REGION=us-east-1
BEDROCK_JUDGE_MODEL=anthropic.claude-3-sonnet-20240229-v1:0

# S3 Configuration
S3_BUCKET=rag-evaluation-datasets
S3_KEY_PREFIX=test-data/

# CloudWatch Configuration
CLOUDWATCH_NAMESPACE=RAGEvaluation
CLOUDWATCH_LOG_GROUP=/aws/rag-evaluation

# Evaluation Configuration
EVALUATION_THRESHOLD_FAITHFULNESS=0.8
EVALUATION_THRESHOLD_RELEVANCE=0.8
EVALUATION_THRESHOLD_CORRECTNESS=0.8

# Pipeline Configuration
PIPELINE_SESSION_ID_PREFIX=rag-eval
PIPELINE_ENABLE_RETRIES=true
PIPELINE_MAX_RETRIES=2

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
