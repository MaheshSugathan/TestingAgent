        <mxCell id="step2-title" value="Step 2: Testcase Generation" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="180" y="365" width="300" height="25" as="geometry" />
        </mxCell>
        
        <mxCell id="step2-desc" value="Help &amp; Support: Sitemap QA Agent generates Q&amp;A testcases + follow-up queries&#xa;Ask Bill + ICFD Billing: Manual testcases + AI-assisted authoring (GitHub Copilot)&#xa;Normalize to a common format: {query, expected/ref (optional), metadata}&#xa;Log testcase counts and provenance" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#424242;" vertex="1" parent="1">
          <mxGeometry x="180" y="390" width="600" height="60" as="geometry" />
        </mxCell>

