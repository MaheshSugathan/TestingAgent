        </mxCell>
        
        <mxCell id="step1-desc" value="Load config from YAML files and environment variables&#xa;Validate AWS credentials and AgentCore connections&#xa;Initialize logging and monitoring systems&#xa;Set up session tracking and error handling" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#424242;" vertex="1" parent="1">
          <mxGeometry x="180" y="250" width="600" height="60" as="geometry" />
