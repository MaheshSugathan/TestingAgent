        <mxCell id="step5-title" value="Step 5: Results and Monitoring" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#00695C;" vertex="1" parent="1">
          <mxGeometry x="180" y="785" width="300" height="25" as="geometry" />
        </mxCell>
        
        <mxCell id="step5-desc" value="Generate per-agent evaluation reports (Ask Bill / ICFD Billing / Help &amp; Support)&#xa;Publish artifacts (JSON/CSV/HTML) to storage and dashboards&#xa;Send metrics/logs to monitoring (CloudWatch or equivalent)&#xa;Display run summary: pass/fail, top issues, and follow-up outcomes" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#424242;" vertex="1" parent="1">
          <mxGeometry x="180" y="810" width="600" height="60" as="geometry" />
        </mxCell>

        <!-- Optional HITL branch (scores below threshold) -->
