        <mxCell id="step4-title" value="Step 4: Evaluation + Follow-up Loop" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#F57C00;" vertex="1" parent="1">
          <mxGeometry x="180" y="645" width="300" height="25" as="geometry" />
        </mxCell>
        
        <mxCell id="step4-desc" value="Help &amp; Support only: generate follow-up queries from responses and trigger back to Dev Agent&#xa;Evaluate responses using Ragas metrics (where applicable) + LLM-as-a-Judge&#xa;Compute overall score and compare to thresholds per agent/test suite&#xa;Optional HITL: interrupt for human approve/reject/override when below threshold" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#424242;" vertex="1" parent="1">
          <mxGeometry x="180" y="670" width="600" height="60" as="geometry" />
        </mxCell>

