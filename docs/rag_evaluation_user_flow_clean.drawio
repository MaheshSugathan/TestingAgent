        <mxCell id="user-desc" value="CLI Command: python run_sitemap_qa_eval.py --sitemap-url https://your-site.com/sitemap.xml&#xa;Specific Page: python run_sitemap_qa_eval.py --page-url https://your-site.com/help/article&#xa;Optional: --no-followup, --output results.json" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#424242;" vertex="1" parent="1">
