        <mxCell id="step3-title" value="Step 3: Dev Agent - Run Queries" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#1565C0;" vertex="1" parent="1">
          <mxGeometry x="180" y="505" width="300" height="25" as="geometry" />
        </mxCell>
        
        <mxCell id="step3-desc" value="Route testcases to the selected target agent: Ask Bill / ICFD Billing / Help &amp; Support&#xa;Invoke via AgentCore/API and collect response + context_used + metadata&#xa;Track latency, token usage (if available), and retries&#xa;Output generated_responses for evaluation + (Help &amp; Support) follow-up generation" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#424242;" vertex="1" parent="1">
          <mxGeometry x="180" y="530" width="600" height="60" as="geometry" />
        </mxCell>

